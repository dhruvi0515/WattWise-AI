# ============================================================
# WattWise AI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
# ============================================================

# ── IBM watsonx.ai Credentials (required for AI features) ──
IBM_API_KEY=your_ibm_api_key_here
PROJECT_ID=your_watsonx_project_id_here
WML_INSTANCE_ID=your_wml_instance_guid_here   # GUID from IBM Cloud Resource List (optional but recommended)

# Regional IBM_URL options — pick the one that matches your watsonx.ai project region:
#   US South  : https://us-south.ml.cloud.ibm.com
#   Sydney    : https://au-syd.ml.cloud.ibm.com
#   EU DE     : https://eu-de.ml.cloud.ibm.com
#   Tokyo     : https://jp-tok.ml.cloud.ibm.com
IBM_URL=https://au-syd.ml.cloud.ibm.com
# Model availability varies by region — check your watsonx.ai project for supported models.
# au-syd available models include: meta-llama/llama-3-1-8b, ibm/granite-3-1-8b-base, ibm/granite-8b-code-instruct
MODEL_ID=ibm/granite-8b-code-instruct

# ── Flask Configuration ──
# IMPORTANT: Change FLASK_SECRET_KEY before any production deployment
FLASK_SECRET_KEY=change-this-to-a-long-random-secret-string
FLASK_DEBUG=False
FLASK_PORT=5000

# ── Application Defaults ──
APP_NAME=WattWise AI
APP_VERSION=3.0.0
ELECTRICITY_RATE=0.12
CURRENCY_SYMBOL=$
COUNTRY=United States

# ── IBM Cloud Object Storage (Optional — future integration) ──
# COS_API_KEY=your_cos_api_key_here
# COS_INSTANCE_ID=your_cos_instance_id_here
# COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
# COS_BUCKET_NAME=wattwise-reports
